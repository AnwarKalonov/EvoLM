{
  "run_name": "baseline_quick",
  "seed": 42,
  "device": "auto",
  "data": {
    "dataset": "tiny_shakespeare",
    "block_size": 128,
    "train_split": 0.9,
    "data_dir": "data"
  },
  "model": {
    "vocab_size": 0,
    "n_layers": 4,
    "n_heads": 4,
    "d_model": 256,
    "dropout": 0.1
  },
  "train": {
    "batch_size": 16,
    "learning_rate": 0.0004,
    "weight_decay": 0.1,
    "betas": [0.9, 0.95],
    "grad_clip": 1.0,
    "eval_interval": 50,
    "eval_steps": 20,
    "max_steps": 250,
    "warmup_steps": 30,
    "gradient_accumulation_steps": 1,
    "save_interval": 100
  },
  "dev_log": [
    "Needed a faster config because waiting forever made debugging painful.",
    "This one is for quick iteration and sanity checks.",
    "Current status: go-to config for rapid prototype runs."
  ]
}
